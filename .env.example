# ══════════════════════════════════════════════════════════════════════════════
# ForexChautari — Environment Variables
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# NEVER commit .env to git — it is already in .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ── JWT authentication (REQUIRED) ────────────────────────────────────────────
# Signs and verifies every access and refresh token.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 characters. If rotated, all existing sessions are immediately
# invalidated — users will need to log in again.
JWT_SECRET=GENERATE_AND_PASTE_JWT_SECRET_HERE
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ── Field encryption (REQUIRED) ───────────────────────────────────────────────
# Encrypts Oanda API keys stored in the database.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Back this up separately from the database.
# If lost, all stored API keys become unreadable and users must reconnect.
FIELD_ENCRYPTION_KEY=GENERATE_AND_PASTE_KEY_HERE

# ── Oanda broker (REQUIRED) ───────────────────────────────────────────────────
# 1. Sign up at https://www.oanda.com/register/#/sign-up/demo  (free practice)
# 2. My Account → Manage API Access → Generate Token
# 3. Account ID shown on dashboard — e.g. 101-001-1234567-001
OANDA_API_KEY=YOUR_OANDA_TOKEN_HERE
OANDA_ACCOUNT_ID=101-001-XXXXXXX-001
OANDA_ENVIRONMENT=practice

# ── Live trading gate ─────────────────────────────────────────────────────────
# Defaults to false. Set true ONLY after thorough review.
# v1 walk-forward accuracy is ~51-53% — close to a coin flip.
# Admins only; non-admin users are always blocked regardless of this flag.
LIVE_TRADING_ENABLED=false

# ── Database (OPTIONAL) ───────────────────────────────────────────────────────
# PostgreSQL connection string. Defaults to SQLite in data/forexchautari.db.
# If you use the provided Docker Compose service, set:
# DATABASE_URL=postgresql://forex_user:change_me_strong_password@localhost:5432/forexchautari
# Otherwise leave unset to continue using SQLite locally.
# DATABASE_URL=postgresql://user:pass@host:5432/forexchautari

# ── Telegram alerts (OPTIONAL) ────────────────────────────────────────────────
# Alerts are silently disabled when these are not set.
# 1. Open Telegram → search @BotFather → /newbot → follow prompts → copy token
# 2. Send any message to your new bot
# 3. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy the "id" from the "chat" object → that is your CHAT_ID
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ── Alpha Vantage (OPTIONAL) ──────────────────────────────────────────────────
# Only needed if using Alpha Vantage as the data source instead of Oanda.
# Free key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=YOUR_AV_KEY_HERE

# ── Database (OPTIONAL) ───────────────────────────────────────────────────────
# SQLite file path relative to the project root. Default is fine for most
# deployments. Change it only if you need the file on a different volume.
DB_PATH=data/forexchautari.db
